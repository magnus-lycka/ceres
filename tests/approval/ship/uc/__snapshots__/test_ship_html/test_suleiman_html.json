{
  "data": {
    "html": "\n<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Suleiman</title>\n<style>\n:root {\n  --paper: #fffdf5;\n  --paper-strong: #f7f1dc;\n  --surface: rgba(255,255,250,0.997);\n  --ink: #0d0d0d;\n  --ink-soft: #353126;\n  --accent: #cc2036;\n  --warning: #ff7a00;\n  --error: #ff1f1f;\n  --frame: #1a1a1a;\n  --line: rgba(39,34,19,0.48);\n  --shadow: rgba(25,22,14,0.08);\n  --page-bg: #8a8a8a;\n  --shell-bg: #fffdf7;\n  --banner-ink: var(--ink);\n  --switch-bg: transparent;\n  --switch-bg-hover: rgba(204,32,54,0.1);\n  --switch-border: rgba(18,18,18,0.5);\n  --switch-ink: var(--ink);\n}\nbody.theme-dark {\n  --paper: #090909;\n  --paper-strong: #111112;\n  --surface: rgba(20,20,21,0.94);\n  --ink: #f2f2ee;\n  --ink-soft: #cfcac0;\n  --accent: #ff3048;\n  --warning: #ffbf00;\n  --error: #ff3030;\n  --frame: #6d6d70;\n  --line: rgba(143,143,148,0.34);\n  --shadow: rgba(0,0,0,0.44);\n  --page-bg: #06060e;\n  --shell-bg: #101012;\n  --banner-ink: var(--ink);\n  --switch-bg: transparent;\n  --switch-bg-hover: rgba(255,48,72,0.12);\n  --switch-border: rgba(232,232,228,0.3);\n  --switch-ink: var(--ink);\n}\n* { box-sizing: border-box; }\nbody {\n  margin: 0;\n  font-family: \"Avenir Next Condensed\",\"DIN Condensed\",\"Arial Narrow\",sans-serif;\n  color: var(--ink);\n  background-color: var(--page-bg);\n}\n.page { min-height: 100vh; padding: 24px; }\n.shell {\n  max-width: 1100px;\n  margin: 0 auto;\n  background: var(--shell-bg);\n  border: 1px solid var(--frame);\n  box-shadow: 0 10px 24px var(--shadow);\n  overflow: hidden;\n}\n.banner { padding: 10px 16px; background: transparent; color: var(--banner-ink); }\n.banner-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }\n.banner-main { min-width: 0; flex: 1 1 auto; }\n.banner-side { flex: 0 0 auto; display: flex; align-items: center; justify-content: flex-end; gap: 8px; }\nh1 {\n  margin: 0;\n  font-size: clamp(1.4rem,3.2vw,2.4rem);\n  line-height: 1;\n  letter-spacing: 0.03em;\n  text-transform: uppercase;\n  color: var(--accent);\n}\n.banner-meta {\n  margin: 0;\n  padding: 8px 14px;\n  border: 1px solid var(--accent);\n  color: var(--ink);\n  font-size: 1.1rem;\n  font-weight: 700;\n  white-space: nowrap;\n  text-align: right;\n}\n.theme-switch {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 2rem;\n  height: 2rem;\n  padding: 0;\n  border: 1px solid var(--switch-border);\n  background: var(--switch-bg);\n  color: var(--switch-ink);\n  font: inherit;\n  font-size: 1rem;\n  line-height: 1;\n  cursor: pointer;\n  border-radius: 999px;\n}\n.theme-switch:hover { background: var(--switch-bg-hover); border-color: var(--accent); }\n.content { padding: 16px 18px 20px; }\n.ship-sheet { display: grid; gap: 18px; }\n.ship-grid {\n  display: grid;\n  grid-template-columns: minmax(0,2.6fr) minmax(260px,1fr);\n  gap: 22px;\n  align-items: start;\n}\n.main-panel {\n  min-width: 0;\n  padding: 10px;\n  background: var(--surface);\n  border: 1px solid var(--accent);\n}\n.spec-table, .mini-table {\n  width: 100%;\n  border-collapse: collapse;\n  table-layout: fixed;\n  background: transparent;\n  color: var(--ink);\n  border: 1px solid var(--accent);\n}\n.spec-table th, .spec-table td, .mini-table th, .mini-table td {\n  padding: 8px 10px;\n  border: 1px solid var(--line);\n  vertical-align: top;\n}\n.spec-table thead th, .mini-table thead th {\n  background: var(--surface);\n  color: var(--ink);\n  font-size: 1.1rem;\n  letter-spacing: 0.03em;\n}\n.main-panel .spec-table { border: 0; background: transparent; }\n.main-panel .spec-table th, .main-panel .spec-table td { border-left: 0; border-right: 0; }\n.main-panel .spec-table thead th { border-top: 0; }\n.main-panel .spec-table tbody tr:last-child td { border-bottom: 0; }\n.main-panel .spec-table .last-section-cell { border-bottom: 0; }\n.spec-table thead th:first-child, .spec-table .section-cell { width: 19%; }\n.spec-table thead th:nth-child(2) { width: 53%; }\n.spec-table .num, .mini-table .num { text-align: right; white-space: nowrap; }\n.power-positive { font-weight: 700; }\n.section-cell { text-align: left; font-weight: 700; }\n.item-cell { line-height: 1.2; }\n.admonition { border-left: 3px solid; padding: 2px 6px; margin: 2px 0 0; border-radius: 0 2px 2px 0; font-size: 0.86rem; line-height: 1.22; }\n.admonition-content { border-color: #8b8f96; background: rgba(80,80,80,0.055); }\n.admonition-info    { border-color: #4a90d9; background: rgba(74,144,217,0.08); }\n.admonition-warning { border-color: var(--warning); background: rgba(255,122,0,0.08); }\n.admonition-error   { border-color: var(--error); background: rgba(255,31,31,0.08); }\n.admonition-title { font-weight: 700; font-size: 0.78em; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1px; }\n.admonition-content .admonition-title { color: #686d75; }\n.admonition-info .admonition-title    { color: #4a90d9; }\n.admonition-warning .admonition-title { color: var(--warning); }\n.admonition-error .admonition-title   { color: var(--error); }\n.ship-sidebar { display: grid; gap: 18px; }\n.sidebar-card { border: 1px solid var(--accent); background: var(--surface); }\n.sidebar-card-title {\n  padding: 9px 14px 8px;\n  background: transparent;\n  color: var(--accent);\n  border-bottom: 1px solid var(--accent);\n  font-size: 1.35rem;\n  line-height: 1;\n  letter-spacing: 0.04em;\n  text-transform: uppercase;\n  text-align: center;\n  font-weight: 800;\n}\n.sidebar-card-body { padding: 10px; }\n.sidebar-card .mini-table { border: 0; background: transparent; }\n.sidebar-card .mini-table th, .sidebar-card .mini-table td { border-left: 0; border-right: 0; }\n.sidebar-card .mini-table thead th { border-top: 0; }\n.sidebar-card .mini-table tbody tr:last-child td { border-bottom: 0; }\n.simple-list {\n  list-style: none;\n  margin: 0;\n  padding: 0;\n  display: grid;\n  gap: 8px;\n  text-align: center;\n  font-size: 1.2rem;\n  color: var(--ink);\n}\n@media (max-width: 960px) { .ship-grid { grid-template-columns: 1fr; } }\n@media (max-width: 720px) { .page { padding: 10px; } .content { padding: 12px 10px 16px; } }\n@media print {\n  body { background: white !important; }\n  .page { min-height: auto; padding: 0; }\n  .shell { max-width: none; border: 0; box-shadow: none; }\n  .theme-switch { display: none; }\n}\n</style>\n</head>\n<body class=\"theme-light\">\n<main class=\"page\">\n<section class=\"shell\">\n<header class=\"banner\">\n  <div class=\"banner-row\">\n    <div class=\"banner-main\">\n      <h1>Suleiman</h1>\n    </div>\n    <div class=\"banner-side\">\n      \n      <p class=\"banner-meta\">Scout/Courier | TL12 | Hull 40</p>\n      \n      <button class=\"theme-switch\" type=\"button\" data-theme-toggle aria-label=\"Switch theme\" title=\"Switch theme\">◐</button>\n    </div>\n  </div>\n</header>\n<section class=\"content\">\n<div class=\"ship-sheet\">\n<div class=\"ship-grid\">\n\n<!-- Main spec table -->\n<section class=\"main-panel\">\n<table class=\"spec-table\">\n<thead><tr><th>Section</th><th>Item</th><th class=\"num\">Tons</th><th class=\"num\">Cost (MCr)</th></tr></thead>\n<tbody>\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"3\">Hull</th>\n  \n  <td class=\"item-cell\">Streamlined Hull</td>\n  <td class=\"num\"><strong>100.00</strong></td>\n  <td class=\"num\">6,000,000</td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Crystaliron, Armour: 4</td>\n  <td class=\"num\">6.00</td>\n  <td class=\"num\">1,200,000</td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Airlock (2 tons)</td>\n  <td class=\"num\"></td>\n  <td class=\"num\"></td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Jump</th>\n  \n  <td class=\"item-cell\">Jump 2</td>\n  <td class=\"num\">10.00</td>\n  <td class=\"num\">15,000,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Propulsion</th>\n  \n  <td class=\"item-cell\">M-Drive 2</td>\n  <td class=\"num\">2.00</td>\n  <td class=\"num\">4,000,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Power</th>\n  \n  <td class=\"item-cell\">Fusion (TL 12), Power 60</td>\n  <td class=\"num\">4.00</td>\n  <td class=\"num\">4,000,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"3\">Fuel</th>\n  \n  <td class=\"item-cell\">J-2, 20 weeks of operation</td>\n  <td class=\"num\">22.00</td>\n  <td class=\"num\"></td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Fuel Scoops</td>\n  <td class=\"num\"></td>\n  <td class=\"num\"></td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Fuel Processor (40 tons/day)</td>\n  <td class=\"num\">2.00</td>\n  <td class=\"num\">100,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Command</th>\n  \n  <td class=\"item-cell\">Standard Bridge</td>\n  <td class=\"num\">10.00</td>\n  <td class=\"num\">500,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"5\">Computer</th>\n  \n  <td class=\"item-cell\">Computer/5/bis</td>\n  <td class=\"num\"></td>\n  <td class=\"num\">45,000</td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Library</td>\n  <td class=\"num\"></td>\n  <td class=\"num\"></td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Manoeuvre/0</td>\n  <td class=\"num\"></td>\n  <td class=\"num\"></td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Intellect</td>\n  <td class=\"num\"></td>\n  <td class=\"num\"></td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Jump Control/2</td>\n  <td class=\"num\"></td>\n  <td class=\"num\">200,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Sensors</th>\n  \n  <td class=\"item-cell\">Military Grade Sensors<div class=\"admonition admonition-content\"><div class=\"admonition-title\">Content</div><div class=\"admonition-body\">Passive optical and thermal sensors, Radar, Lidar, Jammers, EMCON</div></div><div class=\"admonition admonition-info\"><div class=\"admonition-title\">Info</div><div class=\"admonition-body\">DM +0 to Electronics (comms) and Electronics (sensors) checks</div></div></td>\n  <td class=\"num\">2.00</td>\n  <td class=\"num\">4,100,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Weapons</th>\n  \n  <td class=\"item-cell\">Double Turret<div class=\"admonition admonition-info\"><div class=\"admonition-title\">Info</div><div class=\"admonition-body\">No weapons in turret</div></div></td>\n  <td class=\"num\">1.00</td>\n  <td class=\"num\">500,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"2\">Craft</th>\n  \n  <td class=\"item-cell\">Internal Docking Space: Air/Raft</td>\n  <td class=\"num\">5.00</td>\n  <td class=\"num\">1,250,000</td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Air/Raft</td>\n  <td class=\"num\"></td>\n  <td class=\"num\">250,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"1\">Habitation</th>\n  \n  <td class=\"item-cell\">Staterooms × 4<div class=\"admonition admonition-warning\"><div class=\"admonition-title\">Warning</div><div class=\"admonition-body\">Recommended common area is 4.00 tons</div></div></td>\n  <td class=\"num\">16.00</td>\n  <td class=\"num\">2,000,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell\" rowspan=\"2\">Systems</th>\n  \n  <td class=\"item-cell\">Workshop</td>\n  <td class=\"num\">6.00</td>\n  <td class=\"num\">900,000</td>\n</tr>\n\n<tr>\n  \n  <td class=\"item-cell\">Probe Drones × 10</td>\n  <td class=\"num\">2.00</td>\n  <td class=\"num\">1,000,000</td>\n</tr>\n\n\n\n\n<tr>\n  \n  <th scope=\"rowgroup\" class=\"section-cell last-section-cell\" rowspan=\"1\">Cargo</th>\n  \n  <td class=\"item-cell\">Cargo Hold</td>\n  <td class=\"num\">12.00</td>\n  <td class=\"num\"></td>\n</tr>\n\n\n</tbody>\n</table>\n\n</section>\n\n<!-- Sidebar -->\n<aside class=\"ship-sidebar\">\n<section class=\"sidebar-card\">\n  <header class=\"sidebar-card-title\">Crew</header>\n  <div class=\"sidebar-card-body\">\n    \n    <ul class=\"simple-list\"><li>PILOT</li><li>ASTROGATOR</li><li>ENGINEER</li><li>GUNNER</li></ul>\n    \n  </div>\n</section>\n\n<section class=\"sidebar-card\">\n  <header class=\"sidebar-card-title\">Power</header>\n  <div class=\"sidebar-card-body\">\n    <table class=\"mini-table\">\n      <thead><tr><th>Item</th><th class=\"num\">Power</th></tr></thead>\n      <tbody>\n        \n        <tr><td>Power</td><td class=\"num power-positive\">60.00</td></tr>\n        \n        <tr><td>Basic Ship Systems</td><td class=\"num\">20.00</td></tr>\n        \n        <tr><td>Jump</td><td class=\"num\">20.00</td></tr>\n        \n        <tr><td>Propulsion</td><td class=\"num\">20.00</td></tr>\n        \n        <tr><td>Fuel</td><td class=\"num\">2.00</td></tr>\n        \n        <tr><td>Sensors</td><td class=\"num\">2.00</td></tr>\n        \n        <tr><td>Weapons</td><td class=\"num\">1.00</td></tr>\n        \n      </tbody>\n    </table>\n  </div>\n</section>\n<section class=\"sidebar-card\">\n  <header class=\"sidebar-card-title\">Costs</header>\n  <div class=\"sidebar-card-body\">\n    <table class=\"mini-table\">\n      <thead><tr><th>Item</th><th class=\"num\">Amount</th></tr></thead>\n      <tbody>\n        \n        <tr><td>Production Cost</td><td class=\"num\">MCr 41.045</td></tr>\n        \n        <tr><td>Sales Price New</td><td class=\"num\">MCr 36.941</td></tr>\n        \n        <tr><td>Mortgage</td><td class=\"num\">Cr 153,919</td></tr>\n        \n        <tr><td>Maintenance</td><td class=\"num\">Cr 3,078</td></tr>\n        \n        <tr><td>Life Support Facilities</td><td class=\"num\">Cr 4,000</td></tr>\n        \n        <tr><td>Life Support People</td><td class=\"num\">Cr 8,000</td></tr>\n        \n        <tr><td>Fuel</td><td class=\"num\">Cr 4,067</td></tr>\n        \n        <tr><td>Crew Salaries</td><td class=\"num\">Cr 17,000</td></tr>\n        \n        <tr><td>Total Expenses</td><td class=\"num\">Cr 190,063</td></tr>\n        \n      </tbody>\n    </table>\n  </div>\n</section>\n</aside>\n\n</div><!-- ship-grid -->\n</div><!-- ship-sheet -->\n</section><!-- content -->\n</section><!-- shell -->\n</main>\n<script>\nconst body = document.body;\nconst themeToggle = document.querySelector('[data-theme-toggle]');\nfunction setTheme(theme) {\n  body.classList.remove('theme-light','theme-dark');\n  body.classList.add('theme-' + theme);\n  const next = theme === 'dark' ? 'light' : 'dark';\n  if (themeToggle) {\n    themeToggle.setAttribute('aria-label','Switch to ' + next + ' theme');\n    themeToggle.setAttribute('title','Switch to ' + next + ' theme');\n  }\n}\nif (themeToggle) {\n  setTheme(body.classList.contains('theme-dark') ? 'dark' : 'light');\n  themeToggle.addEventListener('click', () => {\n    setTheme(body.classList.contains('theme-dark') ? 'light' : 'dark');\n  });\n}\n</script>\n</body>\n</html>"
  },
  "annotations": {
    "dark_theme_supported": "True"
  }
}
