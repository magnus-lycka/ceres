    "body": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Clio — Wizard — Traveller Character Tools</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/htmx.org@2.0.3/dist/htmx.min.js\"></script>\n  <style>\n    [x-cloak] { display: none !important; }\n    .htmx-indicator { opacity: 0; transition: opacity 0.2s; }\n    .htmx-request .htmx-indicator { opacity: 1; }\n  </style>\n</head>\n<body class=\"bg-gray-950 text-gray-200 min-h-screen font-mono\">\n\n  <nav class=\"bg-gray-900 border-b border-amber-800/40 px-6 py-3 flex gap-6 items-center\">\n    <a href=\"/ui/\" class=\"text-amber-400 font-bold text-lg tracking-widest uppercase\">Ceres</a>\n    <span class=\"text-gray-700\">|</span>\n    <a href=\"/ui/\" class=\"text-gray-400 hover:text-amber-300 text-sm uppercase tracking-wide\">Characters</a>\n  </nav>\n\n  <main class=\"container mx-auto px-6 py-8 max-w-5xl\">\n    \n\n<div id=\"wizard-header\"\n     class=\"flex items-center justify-between mb-6\"\n     >\n  <div>\n    <h1 class=\"text-xl font-bold text-amber-400\">Clio</h1>\n    \n    <p class=\"text-gray-600 text-xs mt-1\">\n      Humaniti\n      · Hexx (Trojan Reach 2715)\n      \n      \n      \n      · Age 18\n    </p>\n  </div>\n  <div class=\"flex items-center gap-4\">\n    <form method=\"POST\" action=\"/ui/characters/1/undo\">\n      <button type=\"submit\"\n              onclick=\"return confirm('Undo the last step?')\"\n              class=\"text-gray-700 hover:text-gray-400 text-xs uppercase tracking-wide\">\n        ← Undo\n      </button>\n    </form>\n    <a href=\"/ui/characters/1\" class=\"text-gray-600 hover:text-gray-400 text-xs uppercase\">View Sheet →</a>\n  </div>\n</div>\n\n<div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n\n  \n  <div class=\"lg:col-span-1 space-y-4\">\n    <div id=\"char-summary\" >\n\n  \n  \n\n  \n\n  \n\n  \n\n  \n\n  \n\n  \n\n</div>\n  </div>\n\n  \n  <div class=\"lg:col-span-2\" id=\"pending-panel\">\n    \n\n\n\n\n\n\n\n\n\n\n<div class=\"border border-amber-700/60 mb-4\">\n  <div class=\"px-4 py-4\">\n    <p class=\"text-sm text-gray-300 mb-4\">Provide characteristics (UCP)</p>\n\n    \n    <form hx-post=\"/ui/characters/1/events\"\n      hx-target=\"#pending-panel\"\n      hx-swap=\"innerHTML\"\n      hx-indicator=\"#spinner\">\n  <input type=\"hidden\" name=\"fulfills\" value=\"3.0\">\n\n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">STR</label>\n    <input type=\"number\" name=\"STR\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">DEX</label>\n    <input type=\"number\" name=\"DEX\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">END</label>\n    <input type=\"number\" name=\"END\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">INT</label>\n    <input type=\"number\" name=\"INT\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">EDU</label>\n    <input type=\"number\" name=\"EDU\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  \n  <div class=\"mb-4\">\n    <label class=\"block text-xs text-gray-500 mb-1\">SOC</label>\n    <input type=\"number\" name=\"SOC\"\n           min=\"1\" max=\"15\"\n           required autofocus\n           class=\"w-32 bg-gray-900 border border-gray-700 text-gray-100 px-3 py-2 text-center text-lg font-bold focus:outline-none focus:border-amber-500\">\n  </div>\n\n  \n  \n\n  <div class=\"flex items-center gap-3\">\n    <button type=\"submit\"\n            class=\"bg-amber-600 hover:bg-amber-500 text-black font-bold px-6 py-2 text-sm uppercase tracking-wide\">\n      Confirm →\n    </button>\n    <span id=\"spinner\" class=\"htmx-indicator text-gray-500 text-xs\">Working…</span>\n  </div>\n</form>\n\n  </div>\n</div>\n\n\n\n\n\n\n  </div>\n\n</div>\n\n\n  </main>\n\n</body>\n</html>"
