    "body": "\n<div id=\"wizard-header\"\n     class=\"flex items-center justify-between mb-6\"\n     hx-swap-oob=\"true\">\n  <div>\n    <h1 class=\"text-xl font-bold text-amber-400\">Oryn</h1>\n    \n    <p class=\"text-gray-600 text-xs mt-1\">\n      Humaniti\n      · Hexx (Trojan Reach 2715)\n      \n      \n      \n      · Age 18\n    </p>\n  </div>\n  <div class=\"flex items-center gap-4\">\n    <form method=\"POST\" action=\"/ui/characters/1/undo\">\n      <button type=\"submit\"\n              onclick=\"return confirm('Undo the last step?')\"\n              class=\"text-gray-700 hover:text-gray-400 text-xs uppercase tracking-wide\">\n        ← Undo\n      </button>\n    </form>\n    <a href=\"/ui/characters/1\" class=\"text-gray-600 hover:text-gray-400 text-xs uppercase\">View Sheet →</a>\n  </div>\n</div>\n<div id=\"char-summary\" hx-swap-oob=\"true\">\n\n  \n  \n  <div class=\"mb-4\">\n    <div class=\"text-xs uppercase tracking-widest text-gray-600 mb-2\">Characteristics</div>\n    \n    <div class=\"grid grid-cols-3 gap-1 text-center text-xs\">\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">STR</div>\n        <div class=\"font-bold text-gray-200\">\n          7\n        </div>\n      </div>\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">DEX</div>\n        <div class=\"font-bold text-gray-200\">\n          8\n        </div>\n      </div>\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">END</div>\n        <div class=\"font-bold text-gray-200\">\n          6\n        </div>\n      </div>\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">INT</div>\n        <div class=\"font-bold text-gray-200\">\n          9\n        </div>\n      </div>\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">EDU</div>\n        <div class=\"font-bold text-amber-300\">\n          10\n        </div>\n      </div>\n      \n      \n      <div class=\"bg-gray-800/50 border border-gray-700/50 py-2\">\n        <div class=\"text-gray-600 text-xs\">SOC</div>\n        <div class=\"font-bold text-gray-200\">\n          5\n        </div>\n      </div>\n      \n    </div>\n  </div>\n  \n\n  \n\n  \n\n  \n\n  \n\n  \n\n  \n\n</div>\n\n\n\n\n\n<div class=\"border border-gray-700/50 bg-gray-800/30 px-4 py-3 mb-4\">\n  <div class=\"text-xs uppercase tracking-widest text-gray-600 mb-2\">What happened</div>\n  <ul class=\"text-xs text-gray-400 space-y-0.5\">\n    \n    <li>DEX 0 → 8</li>\n    \n    <li>EDU 0 → 10</li>\n    \n    <li>END 0 → 6</li>\n    \n    <li>INT 0 → 9</li>\n    \n    <li>SOC 0 → 5</li>\n    \n    <li>STR 0 → 7</li>\n    \n  </ul>\n</div>\n\n\n\n\n\n\n\n<div class=\"border border-amber-700/60 mb-4\">\n  <div class=\"px-4 py-4\">\n    <p class=\"text-sm text-gray-300 mb-4\">Choose 4 background skill(s)</p>\n\n    \n    <form hx-post=\"/ui/characters/1/events\"\n      hx-target=\"#pending-panel\"\n      hx-swap=\"innerHTML\"\n      hx-indicator=\"#spinner\">\n  <input type=\"hidden\" name=\"fulfills\" value=\"2.0\">\n\n  \n\n  \n  <div class=\"mb-4\">\n    \n    <p class=\"text-xs text-gray-500 mb-3\">Choose exactly 4:</p>\n    <div class=\"grid grid-cols-2 gap-1 mb-4 max-h-64 overflow-y-auto\">\n      \n      <label class=\"flex items-center gap-2 px-2 py-1.5 hover:bg-gray-800/50 cursor-pointer text-sm\">\n        <input type=\"checkbox\" name=\"skill\" value=\"{&#34;display_label&#34;:null,&#34;kind&#34;:&#34;ADMIN&#34;,&#34;level&#34;:{&#34;display_label&#34;:null,&#34;value&#34;:0}}\"\n               class=\"accent-amber-500\"\n               onclick=\"enforceLimit(this, 4)\">\n        <span class=\"text-gray-300\">Admin</span>\n     