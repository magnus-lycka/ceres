<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ title | default('') }}{% endblock %}</title>
<style>
:root {
  --paper: #f5f0e8;
  --paper-strong: #e8e0d0;
  --ink: #1a1a1a;
  --ink-soft: #555555;
  --accent: #cc2036;
  --warning: #e07800;
  --error: #cc2036;
  --frame: #cccccc;
}
body.theme-dark {
  --paper: #1a1a1a;
  --paper-strong: #2a2a2a;
  --ink: #e8e0d0;
  --ink-soft: #aaaaaa;
  --frame: #444444;
}
*, *::before, *::after { box-sizing: border-box; }
body {
  margin: 0;
  background: var(--paper);
  color: var(--ink);
  font-family: "Linux Libertine", Georgia, serif;
  font-size: 16px;
}
.shell {
  max-width: 1100px;
  margin: 0 auto;
  background: var(--paper);
  min-height: 100vh;
  padding: 0 0 3rem;
}
.banner {
  background: var(--ink);
  color: var(--paper);
  padding: 1.2rem 2rem;
  display: flex;
  align-items: baseline;
  gap: 1rem;
}
.banner-eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  opacity: 0.7;
  margin-bottom: 0.2rem;
}
.banner h1 {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 700;
  flex: 1;
}
.content { padding: 1.5rem 2rem; }
.catalog-section { margin-bottom: 2.5rem; }
.catalog-section h2 {
  font-size: 1.05rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--accent);
  border-bottom: 1px solid var(--frame);
  padding-bottom: 0.3rem;
  margin-bottom: 0.6rem;
}
.catalog-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}
.catalog-table thead th {
  text-align: right;
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-soft);
  border-bottom: 1px solid var(--frame);
}
.catalog-table thead th:first-child { text-align: left; }
.catalog-table tbody td {
  padding: 0.2rem 0.6rem;
  text-align: right;
  border-bottom: 1px solid var(--paper-strong);
}
.catalog-table tbody td:first-child { text-align: left; }
.catalog-table tbody tr:last-child td { border-bottom: none; }
.catalog-table .note-subrow td {
  font-size: 0.8rem;
  padding-top: 0;
  padding-left: 1.2rem;
  border-bottom: none;
  color: var(--ink-soft);
}
.note-info { font-style: italic; }
.note-warning { color: var(--warning); font-style: italic; }
.note-error { color: var(--error); font-weight: bold; }
{% block extra_css %}{% endblock %}
</style>
{% block extra_head %}{% endblock %}
</head>
<body class="theme-{{ theme | default('light') }}">
<div class="shell">
  <header class="banner">
    <div>
      {% if eyebrow is defined and eyebrow %}<div class="banner-eyebrow">{{ eyebrow }}</div>{% endif %}
      <h1>{% block title_heading %}{{ title | default('') }}{% endblock %}</h1>
    </div>
    {% block banner_side %}{% endblock %}
  </header>
  <div class="content">
    {% block content %}{% endblock %}
  </div>
</div>
<script>
(function(){
  var btn = document.getElementById('theme-toggle');
  if(!btn) return;
  btn.addEventListener('click', function(){
    var b = document.body;
    b.className = b.className === 'theme-light' ? 'theme-dark' : 'theme-light';
  });
})();
</script>
</body>
</html>
